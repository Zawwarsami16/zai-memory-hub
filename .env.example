# Copy this file to .env, fill it in, then point your systemd units or
# shell at it. Anything ending in _TOKEN or _KEY should also live in a
# mode-600 file under auth/ so it can be read by both the dashboard and
# the MCP server without leaking into process listings.

# ---- Postgres ----------------------------------------------------------
# One DSN, used by both services.
ZAI_HUB_DSN=host=127.0.0.1 dbname=zai_hub user=zai_hub password=change-me

# ---- Agent identity ----------------------------------------------------
# Stable slug your MCP writes show up under. Change it per machine,
# not per session. Examples: vps-claude, local-claude, cursor-laptop.
ZAI_HUB_WRITTEN_BY=vps-claude

# Optional: pin a session id so multiple memories from one run cluster.
# Default is vps-<unix-timestamp> at server boot.
# ZAI_HUB_SESSION_ID=

# ---- Bearer token (the one you hand to every agent) --------------------
# Treat as a password. Anything posting to /mcp* must send it as
# `Authorization: Bearer <value>`. Caddy enforces it at the edge.
# Generate one with:
#   python -c "import secrets; print('zai_' + secrets.token_urlsafe(32))"
ZAI_HUB_AGENT_TOKEN=zai_change_me_to_a_long_random_string

# Dashboard login key (separate from the agent token; gates /login).
ZAI_HUB_DASHBOARD_KEY=change-me-dashboard-key

# ---- Public URL (used in QR codes, /connect page, links) ---------------
ZAI_HUB_PUBLIC_URL=https://hub.example.com

# ---- Backblaze B2 (optional; off-VPS nightly backup) -------------------
# Leave blank to disable the backup script. Create a bucket and an
# application key scoped to just that bucket.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_BUCKET_ID=
B2_ENDPOINT=s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005

# ---- Replicate (optional; per-PDF cover art) ---------------------------
# Without this, the "generate cover" checkbox on the upload form is a
# no-op. ~$0.04 per cover at Flux 1.1 Pro pricing.
REPLICATE_API_TOKEN=

# ---- Voyage AI (optional; semantic recall) -----------------------------
# Without this, memory.recall is a substring search. Free tier covers
# a single user comfortably. https://www.voyageai.com
VOYAGE_API_KEY=

# ---- Telegram (optional; status pings) ---------------------------------
# If set, the backup script + dashboard health checks ping here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
